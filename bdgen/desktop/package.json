{
  "name": "bdgen-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "npm run build:windows",
    "build:portable": "npm run build:windows",
    "build:windows": "electron-builder --win portable --config.directories.output=../../build/portable",
    "build:mac": "electron-builder --mac dmg --config.directories.output=../../build/mac",
    "build:linux": "electron-builder --linux AppImage --config.directories.output=../../build/linux",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "pack": "electron-builder --dir",
    "postpack:backend": "node scripts/prepare-backend-resource.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  },
  "build": {
    "appId": "ch.bdgen.desktop",
    "productName": "BdGEN",
    "afterPack": "scripts/prepare-backend-resource.js",
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "extraResources": [
        {
          "from": "../../build/backend/bdgen-server.exe",
          "to": "backend/bdgen-server.exe"
        }
      ],
      "target": [
        "portable"
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "../../build/backend/bdgen-server",
          "to": "backend/bdgen-server"
        }
      ],
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../../build/backend/bdgen-server",
          "to": "backend/bdgen-server"
        }
      ],
      "target": [
        "AppImage"
      ]
    }
  }
}
