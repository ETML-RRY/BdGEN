{
  "name": "bdgen-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "npm run build:portable",
    "build:portable": "electron-builder --win portable --config.directories.output=../../build/portable",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  },
  "build": {
    "appId": "ch.bdgen.desktop",
    "productName": "BdGEN",
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../../build/backend/bdgen-server.exe",
        "to": "backend/bdgen-server.exe"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "portable"
      ]
    }
  }
}
